    "data_models": {
      "robot-fleet-model": {
        "type": "model",
        "name": "Robot Fleet Model",
        "description": "Window Washing Drones And Pressure Washing Rovers With Operational Data",
        "attributes": {
          "device-id": "UUID",
          "model-type": "STRING",
          "serial-number": "STRING",
          "owner-id": "UUID",
          "operator-assignments": "ARRAY<UUID>",
          "status": "ENUM[operational,maintenance,offline,error]",
          "location": "COORDINATES",
          "battery-level": "PERCENTAGE"
        }
      },
      "mission-data-model": {
        "type": "model",
        "name": "Mission Data Model",
        "description": "Mission Planning, Execution, And Completion Data",
        "attributes": {
          "mission-id": "UUID",
          "robot-id": "UUID",
          "start-time": "TIMESTAMP",
          "completion-status": "ENUM[pending,active,completed,failed]",
          "waypoints": "ARRAY<COORDINATES>",
          "coverage-percentage": "PERCENTAGE",
          "duration": "DURATION"
        }
      },
      "telemetry-stream-model": {
        "type": "model",
        "name": "Telemetry Stream Model",
        "description": "Real Time Operational Data From Robots",
        "attributes": {
          "timestamp": "TIMESTAMP",
          "device-id": "UUID",
          "coordinates": "COORDINATES",
          "altitude": "FLOAT",
          "battery": "PERCENTAGE",
          "signal-strength": "INTEGER",
          "weather-conditions": "JSON"
        }
      },
      "user-permissions-model": {
        "type": "model",
        "name": "User Permissions Model",
        "description": "Role Based Access Control And Company Segmentation",
        "attributes": {
          "user-id": "UUID",
          "role-type": "ENUM[owner,operator,teleoperator,fleet-teleoperator,customer-service,operations-manager,executive]",
          "company-id": "UUID",
          "assigned-robots": "ARRAY<UUID>",
          "permission-level": "INTEGER",
          "access-scope": "ENUM[company,fleet,device,none]"
        }
      },
      "parts-inventory-model": {
        "type": "model",
        "name": "Parts Inventory Model",
        "description": "Parts Catalog And Inventory Management",
        "attributes": {
          "part-id": "UUID",
          "part-name": "STRING",
          "part-number": "STRING",
          "robot-compatibility": "ARRAY<STRING>",
          "current-stock": "INTEGER",
          "reorder-threshold": "INTEGER",
          "supplier-id": "UUID",
          "unit-cost": "DECIMAL",
          "lead-time": "DURATION"
        }
      },
      "maintenance-order-model": {
        "type": "model",
        "name": "Maintenance Orders Model",
        "description": "Parts Ordering And Maintenance Workflow Tracking",
        "attributes": {
          "order-id": "UUID",
          "robot-id": "UUID",
          "parts-list": "ARRAY<UUID>",
          "order-status": "ENUM[pending,approved,ordered,shipped,delivered,completed]",

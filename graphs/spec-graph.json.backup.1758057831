    "business_logic": {
      "emergency_stop_logic": {
        "pre_conditions": [
          "Robot must be online and connected",
          "User must have control permissions for this robot"
        ],
        "workflow": [
          "Validate user has permission to control robot",
          "Send emergency stop command to robot",
          "Activate all fail-safe mechanisms",
          "Update robot status to stopped in database",
          "Notify all fleet managers of emergency stop",
          "Log emergency event with timestamp and user ID"
        ],
        "post_conditions": [
          "Robot status shows as stopped",
          "Fail-safe mechanisms are activated",
          "Event is logged in system history"
        ],
        "error_handling": [
          "If command fails, retry up to 3 times",
          "If still failing, escalate to manual override protocol",
          "Always log the attempt regardless of outcome"
        ]
      },
      "mission_assignment_logic": {
        "pre_conditions": [
          "Robot must be in operational status",
          "Robot battery must be above 30%",
          "No active mission currently assigned to robot"
        ],
        "workflow": [
          "Validate mission parameters are complete and valid",
          "Check robot availability and current location",
          "Calculate if mission is feasible with current battery",
          "Reserve robot for this mission exclusively",
          "Create mission record in database",
          "Send mission details to robot",
          "Update fleet dashboard with new assignment"
        ],
        "post_conditions": [
          "Mission record created in database",
          "Robot status updated to on mission",
          "Dashboard reflects new assignment"
        ],
        "business_rules": [
          "Maximum mission duration is 8 hours",
          "Always maintain 20% battery reserve for return journey",
          "Missions queue automatically if no robots available"
        ]
      },
      "telemetry_processing_logic": {
        "data_validation": [
          "Discard any data older than 30 seconds",
          "Validate coordinates are within operational boundaries",
          "Check all sensor values are within expected ranges"
        ],
        "processing_rules": [
          "Normalize all coordinate systems to WGS84",
          "Convert all measurements to metric units",
          "Aggregate data into 5-second windows for analysis"
        ],
        "alert_conditions": [
          "Battery level drops below 20%",
          "Signal lost for more than 10 seconds",
          "Robot deviates more than 50 meters from planned path"
        ]
      },
      "fleet_coordination_logic": {
        "responsibilities": [
          "Coordinate multiple robots to prevent conflicts",
          "Resolve scheduling conflicts between missions",
          "Optimize overall fleet utilization and efficiency"
        ],
        "decision_rules": [
          "Emergency missions always get priority",
          "Assign the closest available robot to new missions",
          "Maintain at least 20% of fleet in reserve for emergencies"
        ],
        "coordination_rules": [
          "Keep robots at least 100 meters apart to prevent collisions",
          "Queue new missions when fleet is at capacity",
          "Synchronize robots working on multi-robot missions"
        ]
      },
      "predictive_maintenance_logic": {
        "monitoring_rules": [
          "Track component usage hours continuously",
          "Monitor sensor readings for anomalies",
          "Calculate wear patterns based on mission types"
        ],
        "prediction_rules": [
          "Alert when component reaches 80% of expected lifespan",
          "Flag unusual vibration patterns indicating wear",
          "Predict maintenance needs 7 days in advance"
        ],
        "scheduling_rules": [
          "Schedule maintenance during low-demand periods",
          "Group maintenance tasks to minimize downtime",
          "Prioritize critical components over cosmetic repairs"
        ]
      },
      "analytics_processing_logic": {
        "data_collection": [
          "Aggregate telemetry data from all robots",
          "Collect mission completion metrics",
          "Track maintenance costs and downtime"
        ],
        "calculation_rules": [
          "Calculate fleet utilization percentage daily",
          "Compute average mission completion time",
          "Determine cost per mission and ROI"
        ],
        "reporting_rules": [
          "Generate daily operational summaries",
          "Create weekly performance reports",
          "Produce monthly executive dashboards"
        ]
      },
      "natural_language_processing_logic": {
        "input_processing": [
          "Parse natural language commands",
          "Identify intent and entities",
          "Map to available robot actions"
        ],
        "validation_rules": [
          "Confirm command is within safety parameters",
          "Verify user has permission for requested action",
          "Check command feasibility with current robot state"
        ],
        "execution_rules": [
          "Translate to robot-specific commands",
          "Queue commands for execution",
          "Provide natural language feedback to user"
        ]
      },
      "anomaly_detection_logic": {
        "detection_rules": [
          "Compare current behavior to historical patterns",
          "Flag deviations beyond 3 standard deviations",
          "Identify sudden changes in sensor readings"
        ],
        "classification_rules": [
          "Categorize anomaly by severity level",
          "Determine if operational or safety related",
          "Assess impact on mission completion"
        ],
        "response_rules": [
          "Alert operators for critical anomalies",
          "Auto-correct minor deviations if safe",
          "Log all anomalies for pattern analysis"
        ]
      },
      "parts_ordering_logic": {
        "inventory_rules": [
          "Monitor parts inventory levels continuously",
          "Calculate usage rates based on maintenance history",
          "Predict future needs based on fleet size"
        ],
        "ordering_rules": [
          "Auto-order when inventory drops below threshold",
          "Bundle orders to reduce shipping costs",
          "Prioritize critical parts over consumables"
        ],
        "approval_workflow": [
          "Generate purchase order with justification",
          "Route to appropriate manager based on cost",
          "Track order status from approval to delivery"
        ]
      },
      "diagnostic_analysis_logic": {
        "data_gathering": [
          "Collect sensor readings from all components",
          "Retrieve error logs and event history",
          "Gather mission performance metrics"
        ],
        "analysis_rules": [
          "Compare readings to baseline values",
          "Identify correlations between failures",
          "Determine root cause of issues"
        ],
        "recommendation_rules": [
          "Suggest immediate fixes for critical issues",
          "Recommend preventive maintenance actions",
          "Provide optimization suggestions"
        ]
      },
      "navigation_to_diagnostics_logic": {
        "navigation_rules": [
          "Preserve current context and filters",
          "Pass selected robot or component ID",
          "Maintain user session state"
        ],
        "display_rules": [
          "Show relevant diagnostics immediately",
          "Highlight areas of concern",
          "Provide quick action buttons"
        ]
      },
      "export_report_logic": {
        "data_selection": [
          "Apply current filters and date ranges",
          "Include selected metrics and KPIs",
          "Aggregate data at appropriate level"
        ],
        "formatting_rules": [
          "Format data for selected export type",
          "Include headers and metadata",
          "Apply company branding if required"
        ],
        "delivery_rules": [
          "Generate file in requested format",
          "Compress if file size exceeds limit",
          "Provide download link or email delivery"
        ]
      },
      "maintenance_approval_logic": {
        "validation_rules": [
          "Verify maintenance request is complete",
          "Check parts availability in inventory",
          "Validate cost estimates are accurate"
        ],
        "approval_workflow": [
          "Route to manager with appropriate authority",
          "Apply approval limits based on cost",
          "Escalate if exceeds normal parameters"
        ],
        "execution_rules": [
          "Create work order upon approval",
          "Reserve required parts from inventory",
          "Schedule technician and robot downtime"
        ]
      }

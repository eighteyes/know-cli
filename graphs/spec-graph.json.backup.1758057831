    "external": {
      "ros-data-streamer": {
        "type": "external_integration",
        "protocol": "ROS2",
        "purpose": "Stream real-time telemetry data from robotic fleet",
        "endpoint": "wss://ros-bridge.example.com/stream",
        "topics": [
          "/telemetry/position",
          "/telemetry/battery",
          "/telemetry/sensors",
          "/telemetry/diagnostics"
        ],
        "message_format": "JSON-ROS",
        "authentication": "JWT",
        "rate_limit": "1000 msg/sec",
        "retry_policy": "exponential_backoff",
        "sample_data": {
          "position": {
            "x": 10.5,
            "y": 20.3,
            "z": 5.1,
            "orientation": {
              "roll": 0.1,
              "pitch": 0.2,
              "yaw": 1.57
            }
          },
          "battery": {
            "voltage": 24.5,
            "current": 3.2,
            "percentage": 87,
            "temperature": 35.2
          },
          "timestamp": "2025-09-16T10:30:45.123Z",
          "robot_id": "fleet-001-drone-042"
        }
      }
    }
  },

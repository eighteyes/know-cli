{
  "meta": {
    "version": "1.0.0", 
    "format": "json-graph",
    "description": "Example of JSON-only graph approach for knowledge maps"
  },

  "content_library": {
    "dashboard-desc": "Primary operational interface showing real-time fleet status and key metrics",
    "fleet-map-desc": "Interactive map displaying real-time robot locations and status indicators",
    "real-time-status-desc": "Live status updates for all fleet devices with <10s data freshness",
    "robot-model-desc": "Core robot entity representing physical devices with operational data"
  },

  "entities": {
    "screen:dashboard": {
      "type": "screen",
      "name": "Fleet Dashboard", 
      "description_ref": "dashboard-desc",
      "route": "/dashboard",
      "priority": "P0"
    },
    "component:fleet-map": {
      "type": "component",
      "name": "Fleet Status Map",
      "description_ref": "fleet-map-desc", 
      "framework": "react",
      "file_path": "src/components/FleetStatusMap/index.tsx"
    },
    "feature:real-time-status": {
      "type": "feature", 
      "name": "Real-Time Status Updates",
      "description_ref": "real-time-status-desc",
      "priority": "P0",
      "version_introduced": "v1"
    },
    "model:robot": {
      "type": "model",
      "name": "Robot",
      "description_ref": "robot-model-desc",
      "database_table": "robots"
    },
    "user:owner": {
      "type": "user",
      "name": "Owner", 
      "access_level": "owned_devices_only"
    }
  },

  "graph": {
    "screen:dashboard": {
      "outbound": {
        "contains": ["component:fleet-map"],
        "implements": ["feature:real-time-status"],
        "depends_on": ["requirement:real-time-updates"]
      },
      "inbound": {
        "accessed_by": ["user:owner", "user:operator"],
        "required_for": ["user-journey:daily-monitoring"]
      }
    },
    "component:fleet-map": {
      "outbound": {
        "implements": ["feature:real-time-status"],
        "uses": ["model:robot"],
        "depends_on": ["integration:websocket-client"]
      },
      "inbound": {
        "contained_by": ["screen:dashboard", "screen:fleet-management"],
        "required_for": ["feature:location-tracking"]
      }
    },
    "feature:real-time-status": {
      "outbound": {
        "uses": ["model:robot"],
        "depends_on": ["requirement:real-time-updates"],
        "enables": ["user-capability:fleet-monitoring"]
      },
      "inbound": {
        "implemented_by": ["component:fleet-map", "component:status-indicator"],
        "contained_in": ["screen:dashboard"],
        "required_by": ["user:owner", "user:operator"]
      }
    },
    "model:robot": {
      "outbound": {
        "relates_to": ["model:user", "model:mission"],
        "stored_in": ["database:postgresql"]
      },
      "inbound": {
        "used_by": ["feature:real-time-status", "feature:robot-assignment"],
        "displayed_by": ["component:fleet-map", "component:robot-card"]
      }
    },
    "user:owner": {
      "outbound": {
        "can_access": ["screen:dashboard", "screen:fleet-management"],
        "can_use": ["feature:robot-assignment", "feature:fleet-analytics"],
        "owns": ["model:robot"]
      },
      "inbound": {
        "served_by": ["screen:dashboard"],
        "workflow_supported": ["user-journey:fleet-management"]
      }
    }
  },

  "indexes": {
    "by_type": {
      "screen": ["dashboard", "fleet-management", "mission-control"],
      "component": ["fleet-map", "status-indicator", "robot-card"],
      "feature": ["real-time-status", "robot-assignment", "fleet-analytics"],
      "model": ["robot", "user", "mission"],
      "user": ["owner", "operator", "teleoperator"]
    },
    "by_priority": {
      "P0": ["screen:dashboard", "feature:real-time-status", "component:fleet-map"],
      "P1": ["feature:fleet-analytics", "screen:business-reports"]
    },
    "by_version": {
      "v1": ["feature:real-time-status", "screen:dashboard", "component:fleet-map"],
      "v2": ["feature:fleet-analytics", "feature:predictive-maintenance"]
    },
    "by_relationship_type": {
      "contains": ["screen:dashboard", "screen:fleet-management"],
      "implements": ["component:fleet-map", "component:status-indicator"],
      "uses": ["feature:real-time-status", "component:fleet-map"],
      "accessed_by": ["screen:dashboard", "feature:robot-assignment"]
    }
  },

  "views": {
    "user_owner_context": {
      "accessible_screens": ["screen:dashboard", "screen:fleet-management"],
      "accessible_features": ["feature:real-time-status", "feature:robot-assignment"],
      "related_components": ["component:fleet-map", "component:robot-assignment-panel"],
      "data_models": ["model:robot", "model:assignment"],
      "user_journey": ["onboard", "assign-robots", "monitor-fleet", "generate-reports"]
    },
    "dashboard_implementation": {
      "required_components": ["component:fleet-map", "component:alert-panel"],
      "required_features": ["feature:real-time-status"],
      "data_dependencies": ["model:robot", "model:alert"],
      "api_dependencies": ["/api/robots/status", "/api/alerts/active"],
      "infrastructure": ["websocket-server", "redis-cache", "postgresql"]
    },
    "feature_real_time_status_impact": {
      "implementing_components": ["component:fleet-map", "component:status-indicator"],
      "appearing_in_screens": ["screen:dashboard", "screen:fleet-management"], 
      "required_models": ["model:robot", "model:telemetry"],
      "required_integrations": ["websocket-client", "data-pipeline"],
      "affected_users": ["user:owner", "user:operator"],
      "dependency_chain": ["model:robot", "integration:data-pipeline", "requirement:real-time-updates"]
    }
  },

  "queries": {
    "find_user_accessible_entities": {
      "description": "Find all entities accessible to a specific user type",
      "jq_query": ".graph | to_entries[] | select(.value.inbound.accessed_by[]? == $user_id) | .key",
      "parameters": ["user_id"],
      "example": "km query find_user_accessible_entities --user_id user:owner"
    },
    "trace_dependency_chain": {
      "description": "Find complete dependency chain for an entity",
      "jq_query": "def find_deps($entity): (.graph[$entity].outbound.depends_on[]? // empty) as $dep | $dep, find_deps($dep); find_deps($entity_id)",
      "parameters": ["entity_id"],
      "example": "km query trace_dependency_chain --entity_id feature:real-time-status"
    },
    "find_circular_dependencies": {
      "description": "Detect circular dependencies in the system",
      "jq_query": "def has_cycle($start; $current; $visited): if $visited | has($current) then if $current == $start then true else false end else (.graph[$current].outbound.depends_on[]? // empty) as $next | has_cycle($start; $next; $visited + {($current): true}) end; .graph | keys[] as $entity | select(has_cycle($entity; $entity; {})) | $entity"
    },
    "impact_analysis": {
      "description": "Find all entities impacted by changing a specific entity",
      "jq_query": "def find_impact($entity): (.graph | to_entries[] | select(.value.outbound | has(\"uses\") and (.uses[] == $entity)) | .key) as $user | $user, find_impact($user); find_impact($entity_id) | unique",
      "parameters": ["entity_id"]
    }
  }
}
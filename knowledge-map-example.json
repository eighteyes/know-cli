{
  "meta": {
    "version": "1.0.0",
    "format": "knowledge-map",
    "cli_compatible": true,
    "project": "lucid-commander"
  },
  
  "content_library": {
    "desc-dashboard-main": "Primary operational interface showing real-time fleet status, key metrics, and alert notifications for fleet management",
    "desc-fleet-map": "Interactive map displaying live robot locations, status indicators, and mission progress with real-time updates",
    "desc-real-time-status": "Live status updates for all fleet devices with <10s data freshness and automated alert generation",
    "desc-owner-user": "Business owners who own robots, employ operators, and require fleet oversight with business intelligence",
    "cap-robot-assignment": "Assign specific robots to designated operators with access control and responsibility tracking",
    "cap-fleet-overview": "View comprehensive fleet status, performance metrics, and operational insights",
    "cap-robot-control": "Direct robot operation including movement, mission execution, and emergency controls",
    "req-real-time": "System must provide data updates with <10s latency for operational data in 95% of cases",
    "req-responsive": "Interface must be responsive and functional on desktop and mobile devices"
  },

  "capability_sets": {
    "basic-operator": ["robot-control", "mission-reports", "device-health-monitoring"],
    "advanced-operator": ["@basic-operator", "fleet-coordination", "emergency-teleoperation"],
    "owner-capabilities": ["robot-assignment", "fleet-overview", "business-reports", "user-management"],
    "lb-staff": ["all-device-diagnostics", "ssh-access", "ros-bag-analysis", "maintenance-systems"]
  },

  "entities": {
    "users": {
      "owner": {
        "id": "owner",
        "type": "user",
        "name": "Owner",
        "description_ref": "desc-owner-user",
        "access_level": "device_owner",
        "capabilities_ref": "owner-capabilities",
        "accessible_screens": ["dashboard", "fleet-management", "business-reports"],
        "accessible_features": ["robot-assignment", "fleet-analytics", "predictive-maintenance"]
      },
      "operator": {
        "id": "operator", 
        "type": "user",
        "name": "Operator",
        "description_ref": "desc-operator-user",
        "access_level": "assigned_devices",
        "capabilities_ref": "basic-operator",
        "accessible_screens": ["dashboard", "robot-control", "mission-planning"],
        "accessible_features": ["robot-control", "mission-management", "status-monitoring"]
      },
      "fleet-teleoperator": {
        "id": "fleet-teleoperator",
        "type": "user", 
        "name": "Fleet Teleoperator",
        "description_ref": "desc-fleet-teleoperator-user",
        "access_level": "fleet_wide",
        "capabilities_ref": "advanced-operator",
        "accessible_screens": ["fleet-coordination", "multi-robot-control", "zone-management"],
        "accessible_features": ["fleet-coordination", "zone-management", "autonomous-oversight"]
      }
    },

    "screens": {
      "dashboard": {
        "id": "dashboard",
        "type": "screen",
        "name": "Fleet Dashboard", 
        "description_ref": "desc-dashboard-main",
        "route": "/dashboard",
        "layout": "main-layout",
        "components": ["fleet-status-map", "metrics-overview", "alert-panel", "quick-actions"],
        "features": ["real-time-status", "fleet-analytics", "alert-system"],
        "user_access": ["owner", "operator", "fleet-teleoperator"],
        "requirements": ["real-time-updates", "responsive-design"],
        "priority": "P0"
      },
      "fleet-management": {
        "id": "fleet-management",
        "type": "screen",
        "name": "Fleet Management",
        "description_ref": "desc-fleet-management",
        "route": "/fleet",
        "layout": "main-layout", 
        "components": ["fleet-status-map", "robot-list", "assignment-panel", "performance-metrics"],
        "features": ["robot-assignment", "fleet-analytics", "performance-monitoring"],
        "user_access": ["owner", "fleet-teleoperator"],
        "requirements": ["real-time-updates", "bulk-operations"],
        "priority": "P0"
      }
    },

    "components": {
      "fleet-status-map": {
        "id": "fleet-status-map",
        "type": "component",
        "name": "Fleet Status Map",
        "description_ref": "desc-fleet-map",
        "framework": "react",
        "file_path": "src/components/FleetStatusMap/index.tsx",
        "dependencies": ["react-leaflet", "websocket-client", "fleet-data-service"],
        "props_interface": "FleetMapProps",
        "used_by_screens": ["dashboard", "fleet-management", "fleet-coordination"],
        "implements_features": ["real-time-status", "location-tracking", "status-visualization"],
        "uses_models": ["robot", "location", "status", "mission"],
        "state_management": "zustand"
      },
      "metrics-overview": {
        "id": "metrics-overview", 
        "type": "component",
        "name": "Metrics Overview",
        "description_ref": "desc-metrics-overview",
        "framework": "react",
        "file_path": "src/components/MetricsOverview/index.tsx",
        "dependencies": ["recharts", "date-fns"],
        "used_by_screens": ["dashboard", "business-reports"],
        "implements_features": ["fleet-analytics", "performance-metrics"],
        "uses_models": ["analytics", "performance-data"],
        "update_frequency": "30s"
      }
    },

    "features": {
      "real-time-status": {
        "id": "real-time-status",
        "type": "feature",
        "name": "Real-Time Status Updates",
        "description_ref": "desc-real-time-status", 
        "priority": "P0",
        "version_introduced": "v1",
        "implementation_status": "active",
        "components": ["fleet-status-map", "status-indicator", "alert-panel"],
        "screens": ["dashboard", "fleet-management"],
        "requirements": ["real-time-updates", "websocket-connection"],
        "models": ["robot", "status", "telemetry", "alert"],
        "api_endpoints": ["/api/status/stream", "/api/robots/status"]
      },
      "robot-assignment": {
        "id": "robot-assignment",
        "type": "feature", 
        "name": "Robot Assignment",
        "description_ref": "cap-robot-assignment",
        "priority": "P0", 
        "version_introduced": "v1",
        "components": ["assignment-panel", "robot-selector", "user-selector"],
        "screens": ["fleet-management", "user-management"],
        "requirements": ["user-permissions", "audit-trail"],
        "models": ["robot", "user", "assignment", "permission"]
      }
    },

    "requirements": {
      "real-time-updates": {
        "id": "real-time-updates",
        "type": "requirement", 
        "name": "Real-Time Updates",
        "description_ref": "req-real-time",
        "priority": "P0",
        "category": "performance",
        "acceptance_criteria_ref": "req-real-time",
        "satisfied_by_features": ["real-time-status", "telemetry-streaming"],
        "impacts_components": ["websocket-client", "data-pipeline", "fleet-status-map"],
        "testing_strategy": "automated_latency_monitoring"
      },
      "responsive-design": {
        "id": "responsive-design",
        "type": "requirement",
        "name": "Responsive Design", 
        "description_ref": "req-responsive",
        "priority": "P1",
        "category": "usability",
        "satisfied_by_features": ["mobile-interface", "adaptive-layouts"],
        "impacts_components": ["main-layout", "fleet-status-map", "metrics-overview"],
        "testing_strategy": "cross_device_testing"
      }
    },

    "models": {
      "robot": {
        "id": "robot",
        "type": "model",
        "name": "Robot", 
        "description_ref": "desc-robot-model",
        "database_table": "robots",
        "primary_key": "id",
        "fields": {
          "id": {"type": "uuid", "required": true},
          "serial_number": {"type": "string", "unique": true},
          "model_type": {"type": "enum", "values": ["window_washing_drone", "pressure_washing_rover"]},
          "status": {"type": "enum", "values": ["active", "maintenance", "offline", "error"]},
          "battery_level": {"type": "number", "range": [0, 100]},
          "location": {"type": "coordinates", "format": "lat_lng"},
          "owner_id": {"type": "uuid", "foreign_key": "users.id"},
          "assigned_operator_id": {"type": "uuid", "foreign_key": "users.id", "nullable": true}
        },
        "relationships": {
          "owner": {"type": "belongs_to", "model": "user"},
          "assigned_operator": {"type": "belongs_to", "model": "user", "nullable": true},
          "missions": {"type": "has_many", "model": "mission"},
          "telemetry": {"type": "has_many", "model": "telemetry"}
        },
        "used_by_features": ["fleet-management", "robot-control", "real-time-status"],
        "used_by_components": ["fleet-status-map", "robot-card", "assignment-panel"]
      },
      "status": {
        "id": "status",
        "type": "model", 
        "name": "Status",
        "description_ref": "desc-status-model",
        "database_table": "robot_status",
        "fields": {
          "robot_id": {"type": "uuid", "foreign_key": "robots.id"},
          "status": {"type": "enum", "values": ["active", "maintenance", "offline", "error"]},
          "battery_level": {"type": "number"},
          "last_seen": {"type": "timestamp"},
          "location": {"type": "coordinates"}
        },
        "update_frequency": "10s",
        "used_by_features": ["real-time-status", "fleet-monitoring"],
        "used_by_components": ["fleet-status-map", "status-indicator"]
      }
    },

    "modules": {
      "fleet-management": {
        "id": "fleet-management",
        "type": "module",
        "name": "Fleet Management",
        "description_ref": "desc-fleet-management-module", 
        "directory": "src/modules/fleet-management",
        "components": ["fleet-status-map", "robot-list", "assignment-panel", "performance-metrics"],
        "features": ["real-time-status", "robot-assignment", "fleet-analytics"],
        "dependencies": ["auth-module", "data-pipeline-module", "websocket-module"],
        "api_routes": ["/api/fleet/*", "/api/robots/*", "/api/assignments/*"],
        "database_tables": ["robots", "robot_status", "assignments"]
      }
    }
  },

  "relationships": {
    "screen:dashboard": {
      "contains": ["component:fleet-status-map", "component:metrics-overview", "component:alert-panel"],
      "implements": ["feature:real-time-status", "feature:fleet-analytics"],
      "accessed_by": ["user:owner", "user:operator", "user:fleet-teleoperator"],
      "depends_on": ["requirement:real-time-updates", "requirement:responsive-design"]
    },
    "component:fleet-status-map": {
      "used_by": ["screen:dashboard", "screen:fleet-management"],
      "implements": ["feature:real-time-status", "feature:location-tracking"],
      "uses": ["model:robot", "model:status", "model:location"],
      "depends_on": ["requirement:real-time-updates"]
    },
    "feature:real-time-status": {
      "implemented_by": ["component:fleet-status-map", "component:status-indicator"],
      "appears_in": ["screen:dashboard", "screen:fleet-management"],
      "requires": ["requirement:real-time-updates", "requirement:websocket-connection"],
      "uses": ["model:robot", "model:status", "model:telemetry"]
    }
  },

  "lookup_tables": {
    "by_user": {
      "owner": {
        "screens": ["dashboard", "fleet-management", "business-reports"],
        "features": ["robot-assignment", "fleet-analytics", "predictive-maintenance"],
        "components": ["fleet-status-map", "metrics-overview", "business-charts"]
      },
      "operator": {
        "screens": ["dashboard", "robot-control", "mission-planning"],
        "features": ["robot-control", "mission-management", "status-monitoring"],
        "components": ["robot-control-panel", "mission-planner", "status-indicator"]
      }
    },
    "by_screen": {
      "dashboard": {
        "components": ["fleet-status-map", "metrics-overview", "alert-panel"],
        "features": ["real-time-status", "fleet-analytics", "alert-system"],
        "users": ["owner", "operator", "fleet-teleoperator"],
        "requirements": ["real-time-updates", "responsive-design"]
      }
    },
    "by_feature": {
      "real-time-status": {
        "screens": ["dashboard", "fleet-management"],
        "components": ["fleet-status-map", "status-indicator", "alert-panel"],
        "requirements": ["real-time-updates", "websocket-connection"],
        "models": ["robot", "status", "telemetry"]
      }
    },
    "by_component": {
      "fleet-status-map": {
        "screens": ["dashboard", "fleet-management", "fleet-coordination"],
        "features": ["real-time-status", "location-tracking", "status-visualization"],
        "models": ["robot", "location", "status", "mission"],
        "dependencies": ["react-leaflet", "websocket-client"]
      }
    }
  }
}
  "references": {
    "descriptions": {
      "lucid-commander-desc": "Robust robot management and control interface for commercial robotics operations with 1000 Window Washing Drones and Pressure Washing Rover",
      "fleet-dashboard-desc": "Real-time fleet status map with device health indicators, active mission assignments, and maintenance alert prioritization",
      "teleoperation-desc": "Real-time robot control over internet with live camera feed, telemetry overlay, and emergency intervention (<200ms latency)",
      "mission-control-desc": "Click and Clean interface for waypoint-based mission planning with autonomous pathfinding and scheduling",
      "device-diagnostics-desc": "Individual device analysis with mission history, component health monitoring, and predictive maintenance triggers",
      "business-intelligence-desc": "Operational metrics including flight time analytics, mission completion rates, fleet utilization, and performance trends",
      "user-management-desc": "Multi-role permission system with Owners, Operators, Teleoperators, Fleet Teleoperators, Customer Service, Operations Managers, and Executives",
      "real-time-telemetry-desc": "Live position, altitude, battery status, environmental data, and mission progress with 5-10s freshness",
      "predictive-maintenance-desc": "Edge-based component health analysis with maintenance alerts and automated scheduling recommendations",
      "natural-language-desc": "Text-to-command processing and voice command integration for hands-free operation",
      "web-platform-desc": "Primary interface with full feature set including Mission Control, Fleet Management, Advanced Diagnostics, and Business Intelligence",
      "mobile-platform-desc": "Field operations interface with essential features: Robot Control, Mission Status, Device Health, Emergency Teleoperation, and Push Notifications",
      "aws-infrastructure-desc": "Data and communication backbone using IoT Core, S3, Kinesis, Glue, PostgreSQL, REST APIs, and WebSocket connections",
      "telemetry-streaming-desc": "WebSocket-based real-time telemetry streaming service with JSON format, gzip compression, supporting up to 1000 concurrent connections",
      "data-aggregation-desc": "Apache Kafka-based real-time data aggregation pipeline with 5-second processing windows and 10k events/second throughput",
      "zone-assignment-desc": "Constraint optimization algorithm for robot zone assignment with O(n²) complexity and <100ms response time",
      "conflict-resolution-desc": "Spatial-temporal analysis engine for multi-robot conflict detection with priority-based routing and 30-second prediction horizon",
      "pathfinding-desc": "A* pathfinding service with dynamic obstacle avoidance, 0.1m map resolution, and 1Hz replanning frequency",
      "ml-health-analysis-desc": "Ensemble regression model for component health analysis using historical telemetry data with <50ms inference latency",
      "predictive-analytics-desc": "30-day forecasting engine with >85% accuracy for predictive analytics, updated daily",
      "nlp-engine-desc": "Transformer-based natural language processing engine with >95% accuracy and <2s response time",
      "dark-theme-desc": "Professional dark theme with rgba(18, 18, 20, 1) background optimized for extended operational use",
      "glass-morphism-desc": "Glass overlay design system with backdrop blur effects for modern interface aesthetics",
      "status-indicators-desc": "Color-coded status system using error red #FF0000, primary blue #0076FE, and secondary blue #33E2FF",
      "interactive-buttons-desc": "White-based interactive elements with transparent overlays and border highlights for clear action feedback",
      "data-visualization-desc": "Chart and graph components optimized for real-time telemetry and analytics display",
      "responsive-layout-desc": "Mobile-first responsive design system with progressive web app capabilities"
    },
    "technical_architecture": {
      "api_gateway": {
        "id": "api-gateway",
        "type": "infrastructure",
        "technology": "AWS API Gateway",
        "base_url": "https://api.lucidbots.com",
        "authentication": "JWT Bearer tokens",
        "rate_limiting": "1000 requests/minute",
        "cors_enabled": true
      },
      "message_broker": {
        "id": "message-broker",
        "type": "infrastructure",
        "technology": "Apache Kafka",
        "cluster_size": "3 nodes",
        "retention_policy": "7 days",
        "partitions": 12
      },
      "database": {
        "id": "primary-database",
        "type": "infrastructure",
        "technology": "PostgreSQL",
        "version": "15.2",
        "connection_pool": 100,
        "backup_frequency": "4 hours"
      },
      "cache_layer": {
        "id": "redis-cache",
        "type": "infrastructure",
        "technology": "Redis",
        "version": "7.0",
        "memory": "16GB",
        "ttl_default": "300s"
      }
    },
    "endpoints": {
      "telemetry_stream": {
        "id": "telemetry-stream-endpoint",
        "method": "WebSocket",
        "path": "/ws/telemetry/{robot_id}",
        "authentication": "required",
        "rate_limit": "100 messages/second",
        "timeout": "30s"
      },
      "fleet_status": {
        "id": "fleet-status-endpoint",
        "method": "GET",
        "path": "/api/v1/fleet/status",
        "response_format": "JSON",
        "cache_ttl": "5s",
        "authentication": "required"
      },
      "mission_control": {
        "id": "mission-control-endpoint",
        "method": "POST",
        "path": "/api/v1/missions",
        "request_format": "JSON",
        "response_format": "JSON",
        "authentication": "required"
      },
      "robot_command": {
        "id": "robot-command-endpoint",
        "method": "POST",
        "path": "/api/v1/robots/{robot_id}/commands",
        "request_format": "JSON",
        "timeout": "5s",
        "authentication": "required"
      }
    },

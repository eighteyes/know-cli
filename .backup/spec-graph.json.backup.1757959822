    "schema": {
      "robot-fleet-model": {
        "type": "model",
        "name": "Robot Fleet Model",
        "description": "Window washing drones and pressure washing rovers with operational data",
        "attributes": {
          "device-id": "UUID",
          "model-type": "STRING",
          "serial-number": "STRING",
          "owner-id": "UUID",
          "operator-assignments": "ARRAY<UUID>",
          "status": "ENUM[operational,maintenance,offline,error]",
          "location": "COORDINATES",
          "battery-level": "PERCENTAGE"
        }
      },
      "mission-data-model": {
        "type": "model",
        "name": "Mission Data Model",
        "description": "Mission planning, execution, and completion data",
        "attributes": {
          "mission-id": "UUID",
          "robot-id": "UUID",
          "start-time": "TIMESTAMP",
          "completion-status": "ENUM[pending,active,completed,failed]",
          "waypoints": "ARRAY<COORDINATES>",
          "coverage-percentage": "PERCENTAGE",
          "duration": "DURATION"
        }
      },
      "telemetry-stream-model": {
        "type": "model",
        "name": "Telemetry Stream Model",
        "description": "Real-time operational data from robots",
        "attributes": {
          "timestamp": "TIMESTAMP",
          "device-id": "UUID",
          "coordinates": "COORDINATES",
          "altitude": "FLOAT",
          "battery": "PERCENTAGE",
          "signal-strength": "INTEGER",
          "weather-conditions": "JSON"
        }
      },
      "user-permissions-model": {
        "type": "model",
        "name": "User Permissions Model",
        "description": "Role-based access control and company segmentation",
        "attributes": {
          "user-id": "UUID",
          "role-type": "ENUM[owner,operator,teleoperator,fleet-teleoperator,customer-service,operations-manager,executive]",
          "company-id": "UUID",
          "assigned-robots": "ARRAY<UUID>",
          "permission-level": "INTEGER",
          "access-scope": "ENUM[company,fleet,device,none]"
        }
      },
      "parts-inventory-model": {
        "type": "model",
        "name": "Parts Inventory Model",
        "description": "Parts catalog and inventory management",
        "attributes": {
          "part-id": "UUID",
          "part-name": "STRING",
          "part-number": "STRING",
          "robot-compatibility": "ARRAY<STRING>",
          "current-stock": "INTEGER",
          "reorder-threshold": "INTEGER",
          "supplier-id": "UUID",
          "unit-cost": "DECIMAL",
          "lead-time": "DURATION"
        }
      },
      "maintenance-order-model": {
        "type": "model",
        "name": "Maintenance Orders Model",
        "description": "Parts ordering and maintenance workflow tracking",
        "attributes": {
          "order-id": "UUID",
          "robot-id": "UUID",
          "parts-list": "ARRAY<UUID>",
          "order-status": "ENUM[pending,approved,ordered,shipped,delivered,completed]",
          "requester-id": "UUID",
          "approver-id": "UUID",
          "supplier-id": "UUID",
          "order-date": "TIMESTAMP",
          "estimated-delivery": "TIMESTAMP",
          "total-cost": "DECIMAL"
        }
      }
    },
    "ui_components": {
      "dark-theme": {
        "id": "dark-theme",
        "type": "ui_component",
        "name": "Dark Theme",
        "description": "Professional dark theme with rgba(18, 18, 20, 1) background optimized for extended operational use"
      },
      "glassmorphism-style": {
        "id": "glass-morphism",
        "type": "ui_component",
        "name": "Glass Morphism Design",
        "description": "Glass overlay design system with backdrop blur effects for modern interface aesthetics"
      },
      "status-indicators": {
        "id": "status-indicators",
        "type": "ui_component",
        "name": "Status Indicator System",
        "description": "Color-coded status system using error red #FF0000, primary blue #0076FE, and secondary blue #33E2FF"
      },
      "button-system": {
        "id": "interactive-buttons",
        "type": "ui_component",
        "name": "Interactive Button Components",
        "description": "White-based interactive elements with transparent overlays and border highlights for clear action feedback"
      },
      "data-visualization": {
        "id": "data-visualization",
        "type": "ui_component",
        "name": "Data Visualization Components",
        "description": "Chart and graph components optimized for real-time telemetry and analytics display"
      },
      "responsive-layout": {
        "id": "responsive-layout",
        "type": "ui_component",
        "name": "Responsive Layout System",
        "description": "Mobile-first responsive design system with progressive web app capabilities"
      }
    },
    "actions": {
      "emergency-stop-robot": {
        "id": "emergency-stop-robot",
        "type": "action",
        "name": "Emergency Stop Robot",
        "description": "Immediately halt all robot operations with fail-safe activation",
        "trigger_type": "button_click",
        "user_roles": [
          "teleoperator",
          "operator",
          "fleet-teleoperator"
        ],
        "state_mutation": {
          "target_model": "robot-fleet",
          "mutation_type": "status_update",
          "new_state": "emergency_stopped"
        },
        "acceptance_criteria": {
          "performance": [
            "action_executed_under_200ms"
          ],
          "functional": [
            "robot_stops_immediately",
            "status_updated_in_ui"
          ],
          "safety": [
            "fail_safe_mechanisms_activated"
          ]
        }
      },
      "assign-mission": {
        "id": "assign-mission",
        "type": "action",
        "name": "Assign Mission to Robot",
        "description": "Assign waypoint-based cleaning mission to specific robot",
        "trigger_type": "form_submission",
        "user_roles": [
          "operator",
          "fleet-teleoperator"
        ],
        "state_mutation": {
          "target_model": "mission-data",
          "mutation_type": "create_record",
          "related_updates": [
            "robot-fleet.status"
          ]
        },
        "acceptance_criteria": {
          "functional": [
            "mission_created_successfully",
            "robot_assigned",
            "ui_updated"
          ],
          "performance": [
            "assignment_processed_under_5_seconds"
          ]
        }
      },
      "navigate-to-diagnostics": {
        "id": "navigate-to-diagnostics",
        "type": "action",
        "name": "Navigate to Device Diagnostics",
        "description": "Navigation action to device diagnostics screen",
        "trigger_type": "navigation_click",
        "user_roles": [
          "owner",
          "customer-service",
          "operations-manager"
        ],
        "state_mutation": {
          "target_model": "ui_state",
          "mutation_type": "screen_change",
          "new_state": "device-diagnostics"
        },
        "acceptance_criteria": {
          "functional": [
            "screen_loads_successfully",
            "user_permissions_validated"
          ],
          "performance": [
            "navigation_under_2_seconds"
          ]
        }
      },
      "approve-maintenance-order": {
        "id": "approve-maintenance-order",
        "type": "action",
        "name": "Approve Maintenance Order",
        "description": "Approve pending maintenance order for parts procurement",
        "trigger_type": "button_click",
        "user_roles": [
          "owner",
          "operations-manager"
        ],
        "state_mutation": {
          "target_model": "maintenance-orders",
          "mutation_type": "status_update",
          "new_state": "approved"
        },
        "acceptance_criteria": {
          "functional": [
            "order_status_updated",
            "supplier_notification_sent"
          ],
          "performance": [
            "approval_processed_under_3_seconds"
          ]
        }
      },
      "export-analytics-report": {
        "id": "export-analytics-report",
        "type": "action",
        "name": "Export Analytics Report",
        "description": "Generate and download analytics report in specified format",
        "trigger_type": "form_submission",
        "user_roles": [
          "owner",
          "executive",
          "operations-manager"
        ],
        "state_mutation": {
          "target_model": "ui_state",
          "mutation_type": "file_generation",
          "new_state": "report_generated"
        },
        "acceptance_criteria": {
          "functional": [
            "report_generated_successfully",
            "file_download_initiated"
          ],
          "performance": [
            "export_completed_under_10_seconds"
          ]
        }
      }
    }
  },

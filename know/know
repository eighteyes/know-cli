#!/bin/bash

# know - Generate implementation specifications from knowledge map
# Zero LLM dependency, pure shell + jq implementation

set -euo pipefail

# Directories - resolve symlinks to get actual script location
SCRIPT_PATH="${BASH_SOURCE[0]}"
# Resolve symlinks
while [[ -h "$SCRIPT_PATH" ]]; do
    SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Use spec-graph.json from current directory if it exists, otherwise fall back to project root
if [[ -f "./.ai/spec-graph.json" ]]; then
    KNOWLEDGE_MAP="${KNOWLEDGE_MAP:-$(pwd)/.ai/spec-graph.json}"
else
    KNOWLEDGE_MAP="${KNOWLEDGE_MAP:-$PROJECT_ROOT/.ai/spec-graph.json}"
fi
LIB_DIR="$SCRIPT_DIR/lib"
TEMPLATE_DIR="${SCRIPT_DIR}/templates"
GENERATOR_DIR="${SCRIPT_DIR}/generators"

# Colors for output
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m'

# Error handling
error() {
    echo -e "${RED}Error: $1${NC}" >&2
    exit 1
}

info() {
    echo -e "${BLUE}$1${NC}" >&2
}

success() {
    echo -e "${GREEN}$1${NC}" >&2
}

# Check dependencies
check_deps() {
    command -v jq >/dev/null 2>&1 || error "jq is required but not installed"
    [[ -f "$KNOWLEDGE_MAP" ]] || error "Knowledge map not found at $KNOWLEDGE_MAP"
}

# Load library functions
source "$LIB_DIR/utils.sh"
source "$LIB_DIR/resolve.sh"
source "$LIB_DIR/query.sh"
source "$LIB_DIR/backend.sh"
source "$LIB_DIR/render.sh"
source "$LIB_DIR/autocomplete.sh"
source "$LIB_DIR/validate-simple.sh"
source "$LIB_DIR/validation-comprehensive.sh"
source "$LIB_DIR/workflows.sh"
source "$LIB_DIR/health.sh"
source "$LIB_DIR/dynamic-commands.sh"
source "$LIB_DIR/connect.sh"

# Show usage
usage() {
    cat << EOF
know - Generate implementation specifications from knowledge map

GENERATE SPECIFICATIONS:
    know feature <entity_id>              Generate feature specification
    know component <entity_id>            Generate component specification
    know screen <entity_id>               Generate screen/UI specification
    know package <entity_id>             Generate complete implementation package
    know test <entity_ref>               Generate test scenarios

GENERATE ARTIFACTS:
    know sitemap                          Generate sitemap with page hierarchy
    know routes                           Generate all pages and API endpoints
    know implementation-chain <entity_ref> Generate full implementation plan
    know priorities                       Generate implementation priorities
    know order                            Generate optimal implementation order

BROWSE & DISCOVER:
    know list [entity_type]               List available entities
    know search <term> [entity_type]     Find entities by name or description
    know feature                          List all features
    know component                        List all components
    know screen                           List all screens

CONNECTION & HEALTH:
    know connect --auto                   Auto-connect with summary & approval
    know connect --auto -y                Skip approval, apply automatically
    know connect --interactive            Review each connection individually
    know connect <entity>                 Find potential connections for entity
    know connect <source> <target>        Connect two specific entities directly
    know health                          Check overall graph health
    know health --readiness              Show readiness scores
    know health --gaps                   Analyze what's missing
    know health --orphans                List disconnected entities
    know health <entity>                 Check specific entity readiness

EXPLORE DEPENDENCIES:
    know deps <entity_ref>                Show dependency chain (alias: up/upstream)
    know impact <entity_ref>              Show what depends on this entity (alias: down/downstream)
    know adjacents <entity_ref>           Show both dependencies and dependents
    know up <entity_ref>                  Show upstream dependencies (what this depends on)
    know down <entity_ref>                Show downstream dependents (what depends on this)
    know preview <type> <entity_id>      Preview what will be generated
    know todo                            Show next actions needed

GRAPH MAINTENANCE:
    know mod <command> [args...]          Modify graph data
    know query <command> [args...]        Query graph data
    know repair [mode]                    Fix structural issues
    know validate <entity_ref>            Validate graph structure

PHASE MANAGEMENT:
    know phases display                   Show implementation phases
    know phases restructure               Generate optimal phases
    know phases stats                     Show phase statistics

LLM INTEGRATION:
    know llm query <prompt> [provider]    Send query to LLM provider
    know llm vision <statement>           Process vision statement
    know llm questions <context>          Generate exploration questions
    know llm extract <text>               Extract entities and connections
    know llm test [provider]              Test provider connectivity
    know llm config                       Manage LLM configuration
    know llm config set <key> [value]     Set configuration value
    know llm config set model             Interactive model selection
    know llm config models [provider]     List available models

OPTIONS:
    --format <md|json|yaml>               Output format (default: md)
    --output <file>                       Save output to file
    --map <file>                          Use custom knowledge map file
    --ai                                  Generate Claude-optimized specification
    --install-completion                  Install bash autocomplete
    --completion-status                   Check autocomplete status
    --help                                Show this help

EXAMPLES:

    # Generate specifications
    know feature real-time-telemetry      # Generate feature spec
    know component fleet-status-map       # Generate component spec
    know package teleoperation-interface  # Generate complete package

    # Generate artifacts
    know sitemap                          # Generate site structure
    know routes                           # Generate routing table
    know implementation-chain feature:auth # Generate implementation plan

    # Check before generating
    know check feature real-time-telemetry # Is it ready to generate?
    know gaps feature:user-auth           # What's missing?
    know deps feature:user-auth           # What dependencies needed?

    # Connect entities in the graph
    know connect --auto                   # Auto-connect by name similarity
    know connect features:fleet-coordination # Find connections for this feature
    know connect features:analytics-system actions:export-analytics-report

    # Fix gaps to enable generation
    know complete feature:auth            # Interactive gap fixing
    know create feature                   # Create new entity to generate from

ENTITY REFERENCE FORMAT:
    <type>:<id>                           Full reference (feature:real-time-telemetry)
    <id>                                  Auto-detect type if unique (real-time-telemetry)

CONFIGURATION:
    KNOWLEDGE_MAP environment variable    Default knowledge map file path

EOF
}

# Parse global options
OUTPUT_FORMAT="md"
OUTPUT_FILE=""
AI_MODE=false

while [[ $# -gt 0 ]]; do
    case $1 in
        --format)
            OUTPUT_FORMAT="$2"
            shift 2
            ;;
        --output)
            OUTPUT_FILE="$2"
            shift 2
            ;;
        --map)
            KNOWLEDGE_MAP="$2"
            shift 2
            ;;
        --ai)
            AI_MODE=true
            shift
            ;;
        --install-completion)
            install_completion
            exit 0
            ;;
        --completion-status)
            completion_status
            exit 0
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        -*)
            error "Unknown option: $1"
            ;;
        *)
            break
            ;;
    esac
done

# Main command dispatcher
main() {
    check_deps
    
    [[ $# -eq 0 ]] && { usage; exit 1; }
    
    local command="$1"
    shift
    
    case "$command" in
        feature|component|screen|functionality|requirement)
            # If no entity_id provided, list entities of this type
            if [[ $# -eq 0 ]]; then
                # Convert singular to plural for entity type
                local entity_type="${command}s"
                if [[ "$command" == "functionality" ]]; then
                    entity_type="functionality"
                fi
                list_entities "$entity_type"
            else
                # Generate spec for specific entity
                local entity_ref=$(resolve_entity_reference "$1" "$command")

                # Phase 1: Check completeness threshold
                local completeness_score
                completeness_score=$(get_completeness_score "$entity_ref")

                if [[ $completeness_score -lt 70 ]]; then
                    error "Cannot generate specification - entity completeness too low ($completeness_score%)

❌ Minimum completeness required: 70%
📊 Current completeness: $completeness_score%
📈 Need: $(( 70 - completeness_score ))% more completeness

🔧 Fix gaps first:
  know gaps $entity_ref
  know validate $entity_ref --comprehensive

Then retry specification generation."
                fi

                info "✅ Completeness check passed ($completeness_score%)"

                echo
                # Phase 2: Generate specification
                if [[ "$AI_MODE" == "true" ]]; then
                    generate_ai_spec "$command" "$entity_ref" "$OUTPUT_FORMAT" "$OUTPUT_FILE"
                else
                    generate_spec "$command" "$entity_ref" "$OUTPUT_FORMAT" "$OUTPUT_FILE"
                fi
            fi
            ;;
        deps|up|upstream)
            [[ $# -ge 1 ]] || error "Usage: know deps <entity_ref>"
            local entity_ref=$(resolve_entity_reference "$1")
            show_dependencies "$entity_ref"
            ;;
        impact|down|downstream)
            [[ $# -ge 1 ]] || error "Usage: know impact <entity_ref>"
            local entity_ref=$(resolve_entity_reference "$1")
            show_impact_analysis "$entity_ref"
            ;;
        adjacents)
            [[ $# -ge 1 ]] || error "Usage: know adjacents <entity_ref>"
            local entity_ref=$(resolve_entity_reference "$1")
            show_adjacents "$entity_ref"
            ;;
        order)
            show_implementation_order
            ;;
        validate)
            if [[ $# -ge 1 && "$1" != --* ]]; then
                # Enhanced entity validation
                local entity_ref=$(resolve_entity_reference "$1")
                local min_score=70
                local comprehensive=false

                # Parse additional options
                shift
                while [[ $# -gt 0 ]]; do
                    case $1 in
                        --comprehensive)
                            comprehensive=true
                            shift
                            ;;
                        --min-score)
                            min_score="$2"
                            shift 2
                            ;;
                        *)
                            shift
                            ;;
                    esac
                done

                if [[ "$comprehensive" == "true" ]]; then
                    validate_entity_comprehensive "$entity_ref" "$min_score"
                else
                    validate_entity_completeness "$entity_ref" "basic"
                fi
            else
                # Original graph validation
                validate_knowledge_map
            fi
            ;;
        validate-deps|check-deps)
            # Validate dependency chains against CLAUDE.md rules
            "$LIB_DIR/validate-dependencies.sh" "$KNOWLEDGE_MAP"
            ;;
        validate-graph)
            # Full graph validation including structure and dependencies
            "$LIB_DIR/validate-spec-graph.sh" "$KNOWLEDGE_MAP" "$LIB_DIR/dependency-rules.json"
            ;;
        cycles)
            detect_cycles
            ;;
        path)
            [[ $# -ge 2 ]] || error "Usage: know path <from_entity> <to_entity>"
            local from_entity=$(resolve_entity_reference "$1")
            local to_entity=$(resolve_entity_reference "$2")
            find_entity_path "$from_entity" "$to_entity"
            ;;
        package)
            [[ $# -ge 1 ]] || error "Usage: know package <entity_id>"
            local entity_ref=$(resolve_entity_reference "$1")
            generate_package "$entity_ref" "$OUTPUT_FORMAT" "$OUTPUT_FILE"
            ;;
        test)
            [[ $# -ge 1 ]] || error "Usage: know test <entity_ref>"
            local entity_ref=$(resolve_entity_reference "$1")
            generate_test_scenarios "$entity_ref" "$OUTPUT_FORMAT" "$OUTPUT_FILE"
            ;;
        list)
            list_entities "${1:-}"
            ;;
        search)
            [[ $# -ge 1 ]] || error "Usage: know search <term> [entity_type]" 
            search_entities "$1" "${2:-}"
            ;;
        preview)
            [[ $# -ge 2 ]] || error "Usage: know preview <type> <entity_id>"
            local entity_ref=$(resolve_entity_reference "$2" "$1")
            preview_generation "$1" "$entity_ref"
            ;;
        check)
            if [[ "$1" == "references" ]] || [[ "$1" == "reference-parents" ]]; then
                # Check that all references have parent entities
                shift
                if [[ "$OUTPUT_FORMAT" == "json" ]]; then
                    "$LIB_DIR/check-reference-parents.sh" --json "$@"
                else
                    "$LIB_DIR/check-reference-parents.sh" "$@"
                fi
            else
                [[ $# -ge 2 ]] || error "Usage: know check <type> <entity_id> OR know check references"
                local entity_ref=$(resolve_entity_reference "$2" "$1")
                validate_entity_completeness "$entity_ref" "$1"
            fi
            ;;
        completeness)
            if [[ $# -ge 1 ]]; then
                if [[ "$OUTPUT_FORMAT" == "json" ]]; then
                    analyze_completeness_batch_json "$1"
                else
                    analyze_completeness_batch "$1"
                fi
            else
                if [[ "$OUTPUT_FORMAT" == "json" ]]; then
                    # Combined JSON output for all entity types
                    {
                        echo '{'
                        echo '  "timestamp": "'$(date -u +%Y-%m-%dT%H:%M:%SZ)'",'
                        echo '  "overall_summary": {'
                        for entity_type in features components screens; do
                            echo "    \"$entity_type\": $(analyze_completeness_batch_json "$entity_type"),"
                        done | sed '$ s/,$//'
                        echo '  }'
                        echo '}'
                    } | jq .
                else
                    echo "📊 Overall Completeness Summary"
                    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                    for entity_type in features components screens; do
                        echo
                        analyze_completeness_batch "$entity_type"
                    done
                fi
            fi
            ;;
        gaps)
            [[ $# -ge 1 ]] || error "Usage: know gaps <entity_ref>"
            local entity_ref=$(resolve_entity_reference "$1")
            validate_entity_comprehensive "$entity_ref" 70 | grep -A 50 "IDENTIFIED GAPS\|RECOMMENDED ACTIONS"
            ;;
        ready-check)
            [[ $# -ge 1 ]] || error "Usage: know ready-check <entity_ref>"
            local entity_ref=$(resolve_entity_reference "$1")
            echo "🎯 Implementation Readiness Check: $entity_ref"
            echo
            if validate_entity_comprehensive "$entity_ref" 70 >/dev/null 2>&1; then
                echo "✅ READY FOR IMPLEMENTATION"
                echo "💡 Proceed with: know spec $entity_ref --complete"
            else
                echo "❌ NOT READY FOR IMPLEMENTATION"
                echo "📋 Run: know gaps $entity_ref"
            fi
            ;;
        blockers)
            if [[ "$OUTPUT_FORMAT" == "json" ]]; then
                # JSON output for blockers
                local all_blockers=()
                
                for entity_type in features components screens; do
                    local entities
                    entities=$("$MOD_GRAPH" list "$entity_type" | grep "  " | awk '{print $1}' | head -10)
                    
                    while IFS= read -r entity_id; do
                        [[ -z "$entity_id" ]] && continue
                        
                        local score
                        score=$(get_completeness_score "${entity_type%s}:$entity_id")
                        
                        if [[ $score -lt 70 ]]; then
                            local blocker_level="needs_work"
                            local blocker_description="Needs additional work"
                            
                            if [[ $score -lt 50 ]]; then
                                blocker_level="critical" 
                                blocker_description="Critical blocker - significant work required"
                            fi
                            
                            local blocker_data
                            blocker_data=$(jq -n \
                                --arg id "$entity_id" \
                                --arg type "${entity_type%s}" \
                                --arg entity_ref "${entity_type%s}:$entity_id" \
                                --argjson score "$score" \
                                --arg level "$blocker_level" \
                                --arg description "$blocker_description" \
                                '{
                                    id: $id,
                                    type: $type,
                                    entity_ref: $entity_ref,
                                    completeness_score: $score,
                                    blocker_level: $level,
                                    description: $description
                                }')
                            all_blockers+=("$blocker_data")
                        fi
                    done <<< "$entities"
                done
                
                # Output JSON
                printf '%s\n' "${all_blockers[@]}" | jq -s \
                    '{
                        timestamp: now,
                        analysis_type: "implementation_blockers",
                        blockers: .,
                        summary: {
                            total_blockers: length,
                            critical: [.[] | select(.blocker_level == "critical")] | length,
                            needs_work: [.[] | select(.blocker_level == "needs_work")] | length
                        },
                        recommendations: [
                            "Address critical blockers first (< 50% completeness)",
                            "Use: know gaps <entity_ref> to see specific missing items",
                            "Use: know complete <entity_ref> for interactive gap fixing"
                        ]
                    }'
            else
                echo "🚧 Implementation Blockers Analysis"
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                echo "Finding entities with low completeness scores..."
                echo
                for entity_type in features components screens; do
                    echo "📋 $entity_type blockers:"
                    analyze_completeness_batch "$entity_type" | grep "🔴\|🟡" | head -5
                    echo
                done
            fi
            ;;
        gap-analyze)
            [[ $# -ge 1 ]] || error "Usage: know gap-analyze <entity_id>"
            local entity_ref=$(resolve_entity_reference "$1")
            "$LIB_DIR/gap-analysis.sh" analyze "$entity_ref"
            ;;
        gap-analyze-all)
            "$LIB_DIR/gap-analysis.sh" analyze-all
            ;;
        gap-summary)
            "$LIB_DIR/gap-analysis.sh" summary
            ;;
        gap-report)
            local format="${1:-text}"
            "$LIB_DIR/gap-reporter.sh" "$format"
            ;;
        chain-builder|gap-qa)
            # gap-qa is kept for backward compatibility but not advertised
            "$GENERATOR_DIR/full-chain-qa.sh"
            ;;
        gap-score)
            [[ $# -ge 1 ]] || error "Usage: know gap-score <entity_id>"
            local entity_ref=$(resolve_entity_reference "$1")
            "$LIB_DIR/completeness-scorer.sh" score "$entity_ref"
            ;;
        todo)
            echo "📝 Next Actions Needed"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo "🔍 Finding entities that need attention..."
            echo
            # Find entities with missing critical components
            local incomplete_features
            incomplete_features=$("$MOD_GRAPH" list features 2>/dev/null | grep "  " | head -5)
            if [[ -n "$incomplete_features" ]]; then
                echo "🎯 High Priority (Features needing work):"
                while IFS= read -r line; do
                    if [[ -n "$line" ]]; then
                        local feature_id=$(echo "$line" | awk '{print $1}')
                        local score=$(get_completeness_score "feature:$feature_id")
                        if [[ $score -lt 70 ]]; then
                            echo "  • feature:$feature_id ($score%) - Run: know gaps feature:$feature_id"
                        fi
                    fi
                done <<< "$incomplete_features"
            fi
            ;;
        completion)
            generate_completion
            ;;
        create)
            # Interactive entity creation - generalized
            local entity_type="${1:-feature}"
            case "$entity_type" in
                feature|features)
                    create_feature_interactive
                    ;;
                component|components)
                    echo "Component creation wizard not yet implemented"
                    echo "Use: know mod add components <id> <name>"
                    ;;
                screen|screens)
                    echo "Screen creation wizard not yet implemented"
                    echo "Use: know mod add screens <id> <name>"
                    ;;
                *)
                    echo "Interactive creation not yet available for: $entity_type"
                    echo "Use: know mod add $entity_type <id> <name>"
                    ;;
            esac
            ;;
        create-feature)
            # Legacy support - redirect to create feature
            create_feature_interactive
            ;;
        complete)
            [[ $# -ge 1 ]] || error "Usage: know complete <entity_ref>"
            local entity_ref=$(resolve_entity_reference "$1")
            complete_entity_interactive "$entity_ref"
            ;;
        implementation-chain)
            [[ $# -ge 1 ]] || error "Usage: know implementation-chain <entity_ref>"
            local entity_ref=$(resolve_entity_reference "$1")
            create_implementation_chain "$entity_ref"
            ;;
        priorities)
            show_implementation_priorities "$OUTPUT_FORMAT"
            ;;
        mod)
            # Forward to mod-graph.sh (has built-in rule validation)
            exec "$LIB_DIR/mod-graph.sh" "$@"
            ;;
        query)
            # Forward to query-graph.sh in know/lib
            exec "$LIB_DIR/query-graph.sh" "$@"
            ;;
        component-map)
            # Forward to component-map.sh in know/lib
            exec "$LIB_DIR/component-map.sh" "$@"
            ;;
        health)
            # Enhanced health command with readiness checks
            health_command "$@"
            ;;
        connect)
            # Smart connection system
            # Check if we're on macOS with old Bash (3.x)
            bash_major="${BASH_VERSION%%.*}"
            if [[ "$bash_major" == "3" ]] || [[ "$bash_major" -lt 4 ]] 2>/dev/null; then
                # Use Mac-compatible version
                case "${1:-}" in
                    --auto)
                        echo -e "${BLUE}Using Mac-compatible auto-connector...${NC}"
                        # Check for -y flag
                        if [[ "${2:-}" == "-y" ]]; then
                            "$LIB_DIR/connect-simple.sh" -y
                        else
                            "$LIB_DIR/connect-simple.sh"
                        fi
                        ;;
                    --interactive)
                        echo -e "${BLUE}Interactive connection mode...${NC}"
                        chmod +x "$LIB_DIR/connect-interactive.sh" 2>/dev/null
                        "$LIB_DIR/connect-interactive.sh" "${@:2}"
                        ;;
                    --help)
                        echo -e "${GREEN}know connect${NC} - Connect entities in the knowledge graph"
                        echo
                        echo "Usage:"
                        echo "  know connect --auto              # Auto-connect entities"
                        echo "  know connect --interactive       # Review connections one by one"
                        echo "  know connect <source> <target>   # Connect two entities"
                        echo "  know connect <entity>            # Find connections for entity"
                        ;;
                    *)
                        if [[ -n "${1:-}" ]] && [[ -n "${2:-}" ]]; then
                            # Direct connection
                            "$LIB_DIR/connect-direct.sh" "$1" "$2"
                        elif [[ -n "${1:-}" ]]; then
                            # Find connections (simplified)
                            "$LIB_DIR/connect-mac.sh" --find "$1"
                        else
                            # Show help
                            echo -e "${GREEN}know connect${NC} - Connect entities in the knowledge graph"
                            echo
                            echo "Usage:"
                            echo "  know connect --auto              # Auto-connect entities"
                            echo "  know connect <source> <target>   # Connect two entities"
                            echo "  know connect <entity>            # Find connections for entity"
                        fi
                        ;;
                esac
            else
                # Bash 4+ - use full version
                if [[ "${1:-}" == "--auto" ]] && [[ "${2:-}" != "--iterative" ]]; then
                    # Use simple connector for basic auto mode
                    echo -e "${BLUE}Using simple auto-connector...${NC}"
                    if [[ "${2:-}" == "-y" ]]; then
                        "$LIB_DIR/connect-simple.sh" -y
                    else
                        "$LIB_DIR/connect-simple.sh"
                    fi
                elif [[ "${1:-}" == "--interactive" ]]; then
                    # Interactive mode
                    chmod +x "$LIB_DIR/connect-interactive.sh" 2>/dev/null
                    "$LIB_DIR/connect-interactive.sh" "${@:2}"
                else
                    # Use full connect.sh for specific connections or iterative mode
                    source "$LIB_DIR/connect.sh"
                    connect_command "$@"
                fi
            fi
            ;;
        repair)
            # Graph repair functionality
            local repair_mode="${1:-interactive}"
            # Handle --interactive and --auto flags
            [[ "$repair_mode" == "--interactive" ]] && repair_mode="interactive"
            [[ "$repair_mode" == "--auto" ]] && repair_mode="auto"
            repair_graph "$KNOWLEDGE_MAP" "$repair_mode"
            ;;
        rules)
            # Show dependency rules
            echo "📋 Dependency Rules (from $LIB_DIR/dependency-rules.json)"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            generate_dynamic_help "$LIB_DIR/dependency-rules.json"
            ;;
        suggest)
            # Suggest valid connections for an entity
            [[ $# -ge 1 ]] || error "Usage: know suggest <entity_ref>"
            local entity_ref=$(resolve_entity_reference "$1")
            suggest_connections "$entity_ref" "$LIB_DIR/dependency-rules.json" "$KNOWLEDGE_MAP"
            ;;
        validate-connection)
            # Validate if a connection is allowed
            [[ $# -ge 2 ]] || error "Usage: know validate-connection <from> <to>"
            local from_ref=$(resolve_entity_reference "$1")
            local to_ref=$(resolve_entity_reference "$2")
            validate_connection "$from_ref" "$to_ref" "$LIB_DIR/dependency-rules.json"
            ;;
        connect-references)
            # Interactive tool to connect orphaned reference keys to entities
            "$LIB_DIR/connect-references.sh" "$@"
            ;;
        sitemap)
            # Generate sitemap showing page hierarchy with components
            shift
            "$GENERATOR_DIR/sitemap.sh" "${1:-.ai/spec-graph.json}"
            ;;
        routes)
            # Show all pages and API endpoints with dependencies
            shift
            "$GENERATOR_DIR/routes.sh" "${1:-.ai/spec-graph.json}"
            ;;
        phases)
            # Phase management functionality
            shift
            exec "$LIB_DIR/phase-manager.sh" "$@"
            ;;
        llm)
            # LLM integration functionality
            # At this point, 'llm' has already been shifted out, so $1 is the subcommand
            local subcommand="${1:-help}"
            shift || true  # Remove subcommand from $@

            # Source the LLM library
            source "$LIB_DIR/llm.sh"

            case "$subcommand" in
                query)
                    # Direct query to LLM
                    if [[ $# -eq 0 ]]; then
                        error "Usage: know llm query <prompt> [provider] [model] [max_tokens] [temperature]"
                    fi
                    llm_query "$@"
                    ;;
                vision)
                    # Process vision statement
                    if [[ $# -eq 0 ]]; then
                        error "Usage: know llm vision <vision_statement> [provider]"
                    fi
                    process_vision "$@"
                    ;;
                questions)
                    # Generate questions
                    if [[ $# -eq 0 ]]; then
                        error "Usage: know llm questions <context> [entity_type] [provider]"
                    fi
                    generate_questions "$@"
                    ;;
                expand)
                    # Expand question with MC/recommendations
                    if [[ $# -eq 0 ]]; then
                        error "Usage: know llm expand <question> [context] [provider]"
                    fi
                    expand_question "$@"
                    ;;
                extract)
                    # Extract nodes/connections
                    if [[ $# -eq 0 ]]; then
                        error "Usage: know llm extract <input_text> [dependency_rules] [provider]"
                    fi
                    extract_nodes "$@"
                    ;;
                update-vision)
                    # Update vision with priorities
                    if [[ $# -lt 2 ]]; then
                        error "Usage: know llm update-vision <current_graph> <new_input> [provider]"
                    fi
                    update_vision "$@"
                    ;;
                pair)
                    # Pair requirements with objectives
                    if [[ $# -lt 2 ]]; then
                        error "Usage: know llm pair <requirements> <objectives> [provider]"
                    fi
                    pair_requirements_objectives "$@"
                    ;;
                infer)
                    # Infer actions from objectives
                    if [[ $# -eq 0 ]]; then
                        error "Usage: know llm infer <objectives> [existing_actions] [provider]"
                    fi
                    infer_actions "$@"
                    ;;
                workpath)
                    # Analyze workpath completion
                    if [[ $# -eq 0 ]]; then
                        error "Usage: know llm workpath <graph_state> [target_feature] [provider]"
                    fi
                    analyze_workpath "$@"
                    ;;
                test)
                    # Test provider connectivity
                    test_provider "${1:-mock}"
                    ;;
                providers)
                    # List available providers
                    list_providers
                    ;;
                config)
                    # Configuration management
                    # config is already shifted out
                    source "$LIB_DIR/llm-config.sh"
                    main "$@"
                    ;;
                mock)
                    # Generate mock response for workflow
                    if [[ $# -eq 0 ]]; then
                        echo "Available mock workflows: vision, questions, extraction"
                        echo "Usage: know llm mock <workflow>"
                    else
                        generate_workflow_mock "$1"
                    fi
                    ;;
                help|--help)
                    echo -e "${GREEN}know llm${NC} - LLM integration for graph manipulation"
                    echo
                    echo "Commands:"
                    echo "  query       - Send direct query to LLM"
                    echo "  vision      - Process vision statement"
                    echo "  questions   - Generate questions for exploration"
                    echo "  expand      - Expand question with MC/recommendations"
                    echo "  extract     - Extract entities/connections from text"
                    echo "  update-vision - Update vision with priorities"
                    echo "  pair        - Pair requirements with objectives"
                    echo "  infer       - Infer actions from objectives"
                    echo "  workpath    - Analyze workpath completion"
                    echo "  test        - Test provider connectivity"
                    echo "  providers   - List available providers"
                    echo "  config      - Manage LLM configuration"
                    echo "  config set  - Set configuration values"
                    echo "  config models - List available models"
                    echo "  mock        - Generate mock responses"
                    echo
                    echo "Environment Variables:"
                    echo "  LLM_PROVIDER    - Default provider (mock, anthropic, lm_studio)"
                    echo "  LLM_MODEL       - Default model name"
                    echo "  LLM_MAX_TOKENS  - Default max tokens"
                    echo "  LLM_TEMPERATURE - Default temperature"
                    echo "  ANTHROPIC_API_KEY - API key for Anthropic"
                    echo "  LM_STUDIO_URL   - URL for LM Studio server"
                    echo
                    echo "Examples:"
                    echo "  know llm query 'Explain quantum computing' anthropic"
                    echo "  know llm vision 'Build a task management app'"
                    echo "  know llm test anthropic"
                    echo "  LLM_PROVIDER=mock know llm questions 'project context'"
                    ;;
                *)
                    error "Unknown LLM subcommand: $subcommand. Use 'know llm help' for usage."
                    ;;
            esac
            ;;
        *)
            error "Unknown command: $command. Use 'know --help' for usage."
            ;;
    esac
}

# Generate specification based on entity type
generate_spec() {
    local spec_type="$1"
    local entity_ref="$2"
    local format="$3"
    local output_file="$4"
    
    # Use our simple working generators for features and screens, fall back to original for others
    if [[ "$spec_type" == "feature" ]]; then
        local generator="$GENERATOR_DIR/simple-feature-spec.sh"
    elif [[ "$spec_type" == "screen" ]]; then
        local generator="$GENERATOR_DIR/simple-screen-spec.sh"
    else
        local generator="$GENERATOR_DIR/${spec_type}-spec.sh"
    fi
    
    if [[ -f "$generator" ]]; then
        info "Generating $spec_type specification for $entity_ref"
        
        # Export necessary environment variables for generator
        export KNOWLEDGE_MAP TEMPLATE_DIR LIB_DIR AI_MODE
        export MOD_GRAPH="$LIB_DIR/mod-graph.sh"
        export JSON_GRAPH_QUERY="$LIB_DIR/query-graph.sh"

        # Change to the know directory so relative paths work
        local original_dir=$(pwd)
        cd "$(dirname "$SCRIPT_DIR")"
        
        # Call the generator directly (not capturing output)
        bash "$generator" "$entity_ref" "$format"

        # Restore original directory
        cd "$original_dir"
    else
        error "No generator found for $spec_type (expected: $generator)"
    fi
}

# Generate AI-optimized specification
generate_ai_spec() {
    local spec_type="$1"
    local entity_ref="$2"
    local format="$3"
    local output_file="$4"
    
    local generator="$GENERATOR_DIR/${spec_type}-spec.sh"
    
    if [[ -f "$generator" ]]; then
        info "Generating AI-optimized $spec_type specification for $entity_ref"
        
        # Export necessary environment variables for generator
        export KNOWLEDGE_MAP TEMPLATE_DIR LIB_DIR AI_MODE
        
        local result
        result=$(bash "$generator" "$entity_ref" "$format")
        
        if [[ -n "$output_file" ]]; then
            echo "$result" > "$output_file"
            success "AI specification written to $output_file"
        else
            echo "$result"
        fi
    else
        error "No generator found for $spec_type (expected: $generator)"
    fi
}

main "$@"

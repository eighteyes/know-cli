    "mobile": {
      "description": "Field Operations - Essential Features",
      "features": [
        "robot_control_local_operations",
        "mission_status_light_reports",
        "device_health_monitoring", 
        "emergency_teleoperation",
        "push_notifications_alerts",
        "voice_command_integration",
        "progressive_web_app_capabilities"
      ],
      "offline_capabilities": {
        "duration": "30_minutes_battery_life",
        "essential_functions": ["arm_disarm", "move", "clean"],
        "local_ai": ["edge_based_pathfinding", "basic_health_analysis"]
      }
    },
    "cloud": {
      "provider": "AWS",
      "description": "Data & Communication Backbone",
      "components": {
        "ingestion": ["iot_core", "s3_bucket_upload"],
        "command_pipeline": "iot_core → ros_edge_devices", 
        "data_processing": ["kinesis", "glue", "s3", "postgresql"],
        "apis": "rest_endpoints_for_all_client_interactions",
        "real_time": "websocket_connections_for_teleoperation",
        "ai_processing": "edge_computing_cloud_ml_integration",
        "multi_tenant": "postgresql_company_data_segregation"
      }
    },
    "edge_computing": {
      "description": "On-device AI and autonomous capabilities",
      "capabilities": [
        "autonomous_pathfinding_execution",
        "component_health_analysis",
        "local_ai_processing",
        "ros_integration_command_execution",
        "offline_operation_30_minutes",
        "telemetry_data_buffering"
      ],
      "constraints": {
        "battery_life": "30_minutes_without_cloud",
        "processing_power": "limited_edge_computing",
        "storage": "limited_local_telemetry_buffering",
        "connectivity": "cellular_wifi_dependency_advanced_features"
      }
    }
  },
